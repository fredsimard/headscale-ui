<%- include('partials/header') %>
<%- include('partials/alerts') %>

<div class="page-header">
  <h1 class="page-title">
    <i class="bi bi-sliders"></i>Preferences
  </h1>
</div>

<div class="card mb-4" style="max-width: 560px">
  <div class="card-header">Headscale</div>
  <div class="card-body">
    <form method="POST" action="/prefs">
      <div class="mb-4">
        <label for="headscaleFqdn" class="form-label">Public URL</label>
        <input type="url" class="form-control" id="headscaleFqdn" name="headscaleFqdn"
          value="<%= headscaleFqdn %>"
          placeholder="https://headscale.example.com">
        <div class="form-text mt-2">
          The public FQDN of your Headscale server, used for client configuration links.
        </div>
      </div>
      <button type="submit" class="btn btn-primary">Save</button>
    </form>
  </div>
</div>

<div class="card" style="max-width: 560px">
  <div class="card-header">Display</div>
  <div class="card-body">
    <form method="POST" action="/prefs">
      <input type="hidden" name="headscaleFqdn" value="<%= headscaleFqdn %>">

      <div class="mb-4">
        <label for="timezone" class="form-label">Time zone</label>
        <select class="form-select" id="timezone" name="timezone" style="border-radius: 12px !important">
          <% allTimezones.forEach(function(z) { %>
          <option value="<%= z %>" <%= z === currentTz ? 'selected' : '' %>><%= z %></option>
          <% }) %>
        </select>
        <div class="form-text mt-2">
          Server default: <strong><%= serverTz %></strong>
        </div>
      </div>

      <div class="mb-4">
        <div class="form-label mb-2">Time format</div>
        <div class="d-flex gap-2">
          <label class="pref-radio-card <%= timeFormat === '12h' ? 'selected' : '' %>">
            <input type="radio" name="timeFormat" value="12h" <%= timeFormat === '12h' ? 'checked' : '' %>>
            <span class="pref-radio-label">12-hour</span>
            <span class="pref-radio-example">2:30 PM</span>
          </label>
          <label class="pref-radio-card <%= timeFormat === '24h' ? 'selected' : '' %>">
            <input type="radio" name="timeFormat" value="24h" <%= timeFormat === '24h' ? 'checked' : '' %>>
            <span class="pref-radio-label">24-hour</span>
            <span class="pref-radio-example">14:30</span>
          </label>
        </div>
      </div>

      <div class="mb-5">
        <div class="form-label mb-2">Date format</div>
        <div class="d-flex gap-2 flex-wrap">
          <label class="pref-radio-card <%= dateFormat === 'long' ? 'selected' : '' %>">
            <input type="radio" name="dateFormat" value="long" <%= dateFormat === 'long' ? 'checked' : '' %>>
            <span class="pref-radio-label">Long</span>
            <span class="pref-radio-example">May 13, 2026, 2:30:15 PM</span>
          </label>
          <label class="pref-radio-card <%= dateFormat === 'medium' ? 'selected' : '' %>">
            <input type="radio" name="dateFormat" value="medium" <%= dateFormat === 'medium' ? 'checked' : '' %>>
            <span class="pref-radio-label">Medium</span>
            <span class="pref-radio-example">May 13, 2026, 2:30 PM</span>
          </label>
          <label class="pref-radio-card <%= dateFormat === 'short' ? 'selected' : '' %>">
            <input type="radio" name="dateFormat" value="short" <%= dateFormat === 'short' ? 'checked' : '' %>>
            <span class="pref-radio-label">Short</span>
            <span class="pref-radio-example">5/13/26, 2:30 PM</span>
          </label>
          <label class="pref-radio-card <%= dateFormat === 'relative' ? 'selected' : '' %>">
            <input type="radio" name="dateFormat" value="relative" <%= dateFormat === 'relative' ? 'checked' : '' %>>
            <span class="pref-radio-label">Relative</span>
            <span class="pref-radio-example">2 days and 3 hours ago</span>
          </label>
        </div>
      </div>

      <button type="submit" class="btn btn-primary">Save</button>
    </form>
  </div>
</div>


<%- include('partials/footer') %>
