<%- include('partials/header') %>
<%- include('partials/alerts') %>

<div class="page-header">
  <h1 class="page-title">
    <i class="bi bi-sliders"></i>Preferences
  </h1>
</div>

<div class="card" style="max-width: 560px">
  <div class="card-header">Display</div>
  <div class="card-body">
    <form method="POST" action="/prefs">
      <div class="mb-2">
        <label for="timezone" class="form-label">Time zone</label>
        <select class="form-select" id="timezone" name="timezone" style="border-radius: 12px !important">
          <% allTimezones.forEach(function(tz) { %>
          <option value="<%= tz %>" <%= tz === currentTz ? 'selected' : '' %>><%= tz %></option>
          <% }) %>
        </select>
        <div class="form-text mt-2">
          Dates and times in the UI are displayed using this zone.
          Server default: <strong><%= serverTz %></strong>.
        </div>
      </div>
      <div class="mt-4">
        <button type="submit" class="btn btn-primary">Save</button>
      </div>
    </form>
  </div>
</div>

<%- include('partials/footer') %>
