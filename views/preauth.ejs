<%- include('partials/header') %>
<%- include('partials/alerts') %>

<div class="page-header">
  <h1 class="page-title">
    <i class="bi bi-key"></i>Pre-Auth Keys
  </h1>
</div>

<div class="row g-4">
  <!-- Sidebar: create form -->
  <div class="col-lg-3">
    <div class="card">
      <div class="card-header">Create key</div>
      <div class="card-body">
        <form method="POST" action="/preauth/create">
          <div class="mb-4">
            <label for="createKeyUser" class="form-label">User</label>
            <select class="form-select" name="user" id="createKeyUser">
              <% users.forEach(u => { %>
              <option value="<%= u.name %>" data-id="<%= u.id %>"
                <%= u.name === defaultUser ? 'selected' : '' %>>
                <%= u.name %>
              </option>
              <% }) %>
            </select>
            <input type="hidden" name="userId" id="createKeyUserId" value="<%= defaultUserId %>">
          </div>
          <div class="mb-4">
            <label for="expiryHours" class="form-label">Expiry (hours)</label>
            <input type="number" class="form-control" id="expiryHours" name="expiry_hours"
              value="24" min="1" max="8760" required>
          </div>
          <div class="mb-3">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="reusable" name="reusable">
              <label class="form-check-label" for="reusable" style="font-size: 14px">Reusable</label>
            </div>
          </div>
          <div class="mb-4">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="ephemeral" name="ephemeral">
              <label class="form-check-label" for="ephemeral" style="font-size: 14px">Ephemeral</label>
            </div>
          </div>
          <button type="submit" class="btn btn-primary w-100">Create key</button>
        </form>
      </div>
    </div>
  </div>

  <!-- Keys table — all users -->
  <div class="col-lg-9">
    <div class="card">
      <div class="card-header">All pre-auth keys</div>
      <div class="table-responsive">
        <table class="table table-hover mb-0" data-sortable>
          <thead>
            <tr>
              <th>User</th>
              <th>Key</th>
              <th>Reusable</th>
              <th>Ephemeral</th>
              <th>Used</th>
              <th>Expiration</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% if (keys.length === 0) { %>
            <tr>
              <td colspan="7">
                <div class="empty-state">
                  <i class="bi bi-key d-block mb-2" style="font-size: 24px;"></i>
                  No pre-auth keys found.
                </div>
              </td>
            </tr>
            <% } %>
            <% keys.forEach(k => {
              const expired = k.expiration && new Date(k.expiration) < new Date();
              const used = k.used || false;
            %>
            <tr class="<%= expired ? 'row-muted' : '' %>">
              <td style="font-weight: 500; color: var(--ink)"><%= k.userName || '—' %></td>
              <td>
                <code class="user-select-all"><%= k.key ? k.key.substring(0, 22) + '…' : '—' %></code>
                <% if (k.key) { %>
                <button class="copy-btn btn-sm" data-key="<%= k.key %>" title="Copy full key">
                  <i class="bi bi-clipboard"></i>
                </button>
                <% } %>
              </td>
              <td>
                <span class="badge bg-<%= k.reusable ? 'success' : 'secondary' %>">
                  <%= k.reusable ? 'Yes' : 'No' %>
                </span>
              </td>
              <td>
                <span class="badge bg-<%= k.ephemeral ? 'info' : 'secondary' %>">
                  <%= k.ephemeral ? 'Yes' : 'No' %>
                </span>
              </td>
              <td>
                <span class="badge bg-<%= used ? 'warning' : 'secondary' %>">
                  <%= used ? 'Yes' : 'No' %>
                </span>
              </td>
              <td style="font-size: 13px" data-value="<%= k.expiration || '' %>">
                <% if (expired) { %>
                <span style="color: #dc2626"><%= formatDate(k.expiration) %></span>
                <% } else if (k.expiration) { %>
                <span style="color: var(--body-text)"><%= formatDate(k.expiration) %></span>
                <% } else { %>
                <span style="color: var(--mute)">—</span>
                <% } %>
              </td>
              <td>
                <% if (!expired) { %>
                <form method="POST" action="/preauth/expire" class="d-inline">
                  <input type="hidden" name="user" value="<%= k.userName %>">
                  <input type="hidden" name="key"  value="<%= k.key %>">
                  <button type="submit" class="btn btn-outline-warning btn-sm" title="Expire key">
                    <i class="bi bi-x-circle"></i>
                  </button>
                </form>
                <% } else { %>
                <span style="font-size: 12px; color: var(--mute)">Expired</span>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>


<%- include('partials/footer') %>
