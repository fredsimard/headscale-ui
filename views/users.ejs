<%- include('partials/header') %>
<%- include('partials/alerts') %>

<div class="page-header">
  <h1 class="page-title">
    <i class="bi bi-people"></i>Users
  </h1>
  <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addUserModal">
    <i class="bi bi-plus"></i>Add user
  </button>
</div>

<div class="d-flex justify-content-center mb-4">
  <div class="search-box-wrapper">
    <i class="bi bi-search search-box-icon"></i>
    <input type="text" class="form-control search-box" id="userSearch"
      placeholder="Search users…" data-table="usersTable">
  </div>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover mb-0" data-sortable id="usersTable">
      <thead>
        <tr>
          <th>ID</th>
          <th>Username</th>
          <th>Display name</th>
          <th>Email</th>
          <th>Created</th>
          <th>Keys</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% if (users.length === 0) { %>
        <tr>
          <td colspan="7">
            <div class="empty-state">
              <i class="bi bi-people d-block mb-2" style="font-size: 24px;"></i>
              No users found.
            </div>
          </td>
        </tr>
        <% } %>
        <% users.forEach(u => { %>
        <tr>
          <td><code><%= u.id %></code></td>
          <td style="font-weight: 500; color: var(--ink)"><a href="/devices?search=<%= encodeURIComponent(u.name) %>" class="table-link" style="font-weight: 500; color: var(--ink)"><%= u.name %></a></td>
          <td style="color: var(--body-text)"><%= u.displayName || '—' %></td>
          <td style="color: var(--body-text)"><%= u.email || '—' %></td>
          <td style="font-size: 13px; color: var(--body-text)" data-value="<%= u.createdAt || '' %>">
            <%= formatDate(u.createdAt) %>
          </td>
          <td>
            <% var keyCount = keyCounts[u.name] || 0; %>
            <% if (keyCount > 0) { %>
            <a href="/preauth?user=<%= encodeURIComponent(u.name) %>" class="key-count-badge"><%= keyCount %></a>
            <% } else { %>
            <span style="color: var(--mute); font-size: 13px">—</span>
            <% } %>
          </td>
          <td>
            <div class="d-flex gap-2">
              <button class="btn btn-outline-primary btn-sm" data-bs-toggle="modal"
                data-bs-target="#renameUserModal"
                data-user-id="<%= u.id %>"
                data-user-name="<%= u.name %>"
                title="Rename user">
                <i class="bi bi-pencil"></i>
              </button>
              <button class="btn btn-outline-danger btn-sm" data-bs-toggle="modal"
                data-bs-target="#deleteUserModal"
                data-user-id="<%= u.id %>"
                data-user-name="<%= u.name %>"
                title="Delete user">
                <i class="bi bi-trash"></i>
              </button>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<!-- Rename User Modal -->
<div class="modal fade" id="renameUserModal" tabindex="-1">
  <div class="modal-dialog">
    <form method="POST" action="/users/rename" class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Rename user</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" name="id" id="renameUserId">
        <div class="mb-2">
          <label for="renameUserName" class="form-label">New username</label>
          <input type="text" class="form-control" id="renameUserName" name="newName"
            pattern="[a-zA-Z0-9._-]+" required>
          <div class="form-text mt-2">Letters, numbers, dots, underscores, and hyphens only.</div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">Rename</button>
      </div>
    </form>
  </div>
</div>

<!-- Add User Modal -->
<div class="modal fade" id="addUserModal" tabindex="-1">
  <div class="modal-dialog">
    <form method="POST" action="/users/create" class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Add user</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-2">
          <label for="userName" class="form-label">Username</label>
          <input type="text" class="form-control" id="userName" name="name"
            pattern="[a-zA-Z0-9._-]+" placeholder="alice" required>
          <div class="form-text mt-2">Letters, numbers, dots, underscores, and hyphens only.</div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">Create user</button>
      </div>
    </form>
  </div>
</div>

<!-- Delete User Modal -->
<div class="modal fade" id="deleteUserModal" tabindex="-1">
  <div class="modal-dialog">
    <form method="POST" action="/users/delete" class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title text-danger">Delete user</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" name="id" id="deleteUserId">
        <p style="color: var(--charcoal); margin-bottom: 8px">
          Delete user <strong id="deleteUserLabel" style="color: var(--ink)"></strong>?
        </p>
        <p style="font-size: 13px; color: var(--mute); margin: 0">
          This will also remove all devices and keys associated with this user.
        </p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-danger">Delete user</button>
      </div>
    </form>
  </div>
</div>


<%- include('partials/footer') %>
