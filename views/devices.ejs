<%- include('partials/header') %>
<%- include('partials/alerts') %>

<div class="page-header">
  <h1 class="page-title">
    <i class="bi bi-pc-display"></i>Devices
  </h1>
  <div class="d-flex align-items-center gap-3">
    <div class="d-flex gap-1">
      <button class="btn btn-primary btn-sm status-filter active" data-filter="all">All</button>
      <button class="btn btn-secondary btn-sm status-filter" data-filter="online">Online</button>
      <button class="btn btn-secondary btn-sm status-filter" data-filter="offline">Offline</button>
    </div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#registerModal">
      <i class="bi bi-plus"></i>Register device
    </button>
  </div>
</div>

<div class="d-flex justify-content-center mb-4">
  <div class="search-box-wrapper">
    <i class="bi bi-search search-box-icon"></i>
    <input type="text" class="form-control search-box" id="deviceSearch"
      placeholder="Search devices…" data-table="devicesTable">
  </div>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover mb-0" data-sortable id="devicesTable">
      <thead>
        <tr>
          <th>ID</th>
          <th>Hostname</th>
          <th>Machine name</th>
          <th>User</th>
          <th>Tags</th>
          <th>IP addresses</th>
          <th>Ephemeral</th>
          <th>Last seen</th>
          <th>Expiry</th>
          <th>Status</th>
          <th>Pre-Auth Key</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% if (nodes.length === 0) { %>
        <tr>
          <td colspan="12">
            <div class="empty-state">
              <i class="bi bi-pc-display d-block mb-2" style="font-size: 24px;"></i>
              No devices registered yet.
            </div>
          </td>
        </tr>
        <% } %>
        <% nodes.forEach(node => { %>
        <%
          const online  = node.online || false;
          const expired = node.expiry && new Date(node.expiry) < new Date() && new Date(node.expiry).getFullYear() > 1970;
          const lastSeen = formatDate(node.lastSeen);
          const expiry   = node.expiry && new Date(node.expiry).getFullYear() > 1970
            ? formatDate(node.expiry) : 'Never';
          const ips      = node.ipAddresses ? node.ipAddresses.join(', ') : '—';
          const userName = node.user ? (node.user.name || node.user.displayName || '—') : '—';
          const pak      = node.preAuthKey || null;
          const pakTags  = (pak && pak.aclTags) || [];
          const nodeTags = node.tags || [];
          // Merge node-level tags with preAuthKey aclTags, deduplicated
          const tagSet   = {};
          nodeTags.concat(pakTags).forEach(function(t) { tagSet[t] = true; });
          const tags     = Object.keys(tagSet);
        %>
        <tr data-status="<%= online ? 'online' : 'offline' %>" class="<%= !online ? 'row-muted' : '' %>">
          <td><code><%= node.id %></code></td>
          <td style="font-weight: 500; color: var(--ink)"><%= node.givenName || node.name || '—' %></td>
          <td style="color: var(--mute); font-size: 13px"><%= node.name || '—' %></td>
          <td><% if (userName !== '—') { %><a href="/users?search=<%= encodeURIComponent(userName) %>" class="table-link"><%= userName %></a><% } else { %>—<% } %></td>
          <td>
            <% if (tags.length > 0) { %>
            <div class="tag-list">
              <% tags.forEach(function(tag) { %>
              <span class="tag-pill"><%= tag.replace(/^tag:/, '') %></span>
              <% }) %>
            </div>
            <% } else { %>
            <span style="color: var(--mute)">—</span>
            <% } %>
          </td>
          <td>
            <div class="ip-list">
              <% (node.ipAddresses || []).forEach(function(ip) { %>
              <button class="ip-pill" data-ip="<%= ip %>" title="Copy <%= ip %>"><%= ip %></button>
              <% }) %>
              <% if (!node.ipAddresses || node.ipAddresses.length === 0) { %>
              <span style="color: var(--mute)">—</span>
              <% } %>
            </div>
          </td>
          <td>
            <% if (node.ephemeral) { %>
            <span class="badge bg-info">Yes</span>
            <% } else { %>
            <span class="badge bg-secondary">No</span>
            <% } %>
          </td>
          <td style="font-size: 13px; color: var(--body-text)" data-value="<%= node.lastSeen || '' %>"><%= lastSeen %></td>
          <td style="font-size: 13px" data-value="<%= node.expiry || '' %>">
            <% if (expired) { %>
            <span style="color: #dc2626"><%= expiry %></span>
            <% } else { %>
            <span style="color: var(--body-text)"><%= expiry %></span>
            <% } %>
          </td>
          <td>
            <% if (online) { %>
            <span class="badge bg-success">Online</span>
            <% } else { %>
            <span class="badge bg-secondary">Offline</span>
            <% } %>
          </td>
          <td>
            <% if (pak && pak.key) { %>
            <a href="/preauth?user=<%= encodeURIComponent(userName) %>" class="key-count-badge" title="<%= pak.key %>">
              <%= pak.key.substring(0, 8) %>…
            </a>
            <% } else { %>
            <span style="color: var(--mute)">—</span>
            <% } %>
          </td>
          <td>
            <div class="d-flex gap-2">
              <button class="btn btn-outline-primary btn-sm" data-bs-toggle="modal"
                data-bs-target="#renameModal"
                data-node-id="<%= node.id %>"
                data-node-name="<%= node.givenName || node.name || '' %>"
                title="Rename">
                <i class="bi bi-pencil"></i>
              </button>
              <button class="btn btn-outline-danger btn-sm" data-bs-toggle="modal"
                data-bs-target="#deleteModal"
                data-node-id="<%= node.id %>"
                data-node-name="<%= node.givenName || node.name || '' %>"
                title="Delete">
                <i class="bi bi-trash"></i>
              </button>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<!-- Register Device Modal -->
<div class="modal fade" id="registerModal" tabindex="-1">
  <div class="modal-dialog">
    <form method="POST" action="/devices/register" class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Register device</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-4">
          <label for="regUser" class="form-label">User</label>
          <select class="form-select" id="regUser" name="user" required>
            <% users.forEach(u => { %>
            <option value="<%= u.name %>"><%= u.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="mb-2">
          <label for="regKey" class="form-label">Node key</label>
          <input type="text" class="form-control" id="regKey" name="key"
            placeholder="nodekey:abc123…" required>
          <div class="form-text mt-2">The key generated on the device (starts with <code>nodekey:</code>).</div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">Register</button>
      </div>
    </form>
  </div>
</div>

<!-- Rename Modal -->
<div class="modal fade" id="renameModal" tabindex="-1">
  <div class="modal-dialog">
    <form method="POST" action="/devices/rename" class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Rename device</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" name="nodeId" id="renameNodeId">
        <div class="mb-2">
          <label for="newName" class="form-label">New name</label>
          <input type="text" class="form-control" id="newName" name="newName" required>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">Rename</button>
      </div>
    </form>
  </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
  <div class="modal-dialog">
    <form method="POST" action="/devices/delete" class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title text-danger">Delete device</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" name="nodeId" id="deleteNodeId">
        <p style="color: var(--charcoal); margin-bottom: 8px">
          Delete <strong id="deleteNodeName" style="color: var(--ink)"></strong>?
        </p>
        <p style="font-size: 13px; color: var(--mute); margin: 0">This action cannot be undone.</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-danger">Delete</button>
      </div>
    </form>
  </div>
</div>


<%- include('partials/footer') %>
