<%- include('partials/header') %>
<%- include('partials/alerts') %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h2><i class="bi bi-pc-display me-2"></i>Devices</h2>
  <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#registerModal">
    <i class="bi bi-plus-circle me-1"></i>Register Device
  </button>
</div>

<div class="card shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover table-striped mb-0">
      <thead class="table-dark">
        <tr>
          <th>ID</th>
          <th>Hostname</th>
          <th>Name</th>
          <th>User</th>
          <th>IP Addresses</th>
          <th>Ephemeral</th>
          <th>Last Seen</th>
          <th>Expiry</th>
          <th>Online</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (nodes.length === 0) { %>
        <tr><td colspan="10" class="text-center text-muted py-4">No devices found.</td></tr>
        <% } %>
        <% nodes.forEach(node => { %>
        <%
          const online = node.online || false;
          const expired = node.expiry && new Date(node.expiry) < new Date() && new Date(node.expiry).getFullYear() > 1970;
          const lastSeen = node.lastSeen ? new Date(node.lastSeen).toLocaleString() : '—';
          const expiry = node.expiry && new Date(node.expiry).getFullYear() > 1970
            ? new Date(node.expiry).toLocaleString()
            : 'Never';
          const ips = node.ipAddresses ? node.ipAddresses.join(', ') : '—';
          const userName = node.user ? (node.user.name || node.user.displayName || '—') : '—';
        %>
        <tr>
          <td><code><%= node.id %></code></td>
          <td><%= node.givenName || node.name || '—' %></td>
          <td><small class="text-muted"><%= node.name || '—' %></small></td>
          <td><%= userName %></td>
          <td><code class="small"><%= ips %></code></td>
          <td>
            <% if (node.ephemeral) { %>
            <span class="badge bg-info">Yes</span>
            <% } else { %>
            <span class="badge bg-secondary">No</span>
            <% } %>
          </td>
          <td class="small"><%= lastSeen %></td>
          <td class="small">
            <% if (expired) { %>
            <span class="text-danger"><%= expiry %></span>
            <% } else { %>
            <%= expiry %>
            <% } %>
          </td>
          <td>
            <% if (online) { %>
            <span class="badge bg-success">Online</span>
            <% } else { %>
            <span class="badge bg-danger">Offline</span>
            <% } %>
          </td>
          <td>
            <div class="btn-group btn-group-sm">
              <button class="btn btn-outline-primary" data-bs-toggle="modal"
                data-bs-target="#renameModal"
                data-node-id="<%= node.id %>"
                data-node-name="<%= node.givenName || node.name || '' %>">
                <i class="bi bi-pencil"></i>
              </button>
              <button class="btn btn-outline-danger" data-bs-toggle="modal"
                data-bs-target="#deleteModal"
                data-node-id="<%= node.id %>"
                data-node-name="<%= node.givenName || node.name || '' %>">
                <i class="bi bi-trash"></i>
              </button>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<!-- Register Device Modal -->
<div class="modal fade" id="registerModal" tabindex="-1">
  <div class="modal-dialog">
    <form method="POST" action="/devices/register" class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Register Device</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label for="regUser" class="form-label">User</label>
          <select class="form-select" id="regUser" name="user" required>
            <% users.forEach(u => { %>
            <option value="<%= u.name %>"><%= u.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="mb-3">
          <label for="regKey" class="form-label">Node Key</label>
          <input type="text" class="form-control" id="regKey" name="key"
            placeholder="nodekey:abc123..." required>
          <div class="form-text">The key generated on the device (starts with <code>nodekey:</code>).</div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">Register</button>
      </div>
    </form>
  </div>
</div>

<!-- Rename Modal -->
<div class="modal fade" id="renameModal" tabindex="-1">
  <div class="modal-dialog">
    <form method="POST" action="/devices/rename" class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Rename Device</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" name="nodeId" id="renameNodeId">
        <div class="mb-3">
          <label for="newName" class="form-label">New Name</label>
          <input type="text" class="form-control" id="newName" name="newName" required>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">Rename</button>
      </div>
    </form>
  </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
  <div class="modal-dialog">
    <form method="POST" action="/devices/delete" class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title text-danger">Delete Device</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" name="nodeId" id="deleteNodeId">
        <p>Are you sure you want to delete <strong id="deleteNodeName"></strong>?</p>
        <p class="text-danger small">This action cannot be undone.</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-danger">Delete</button>
      </div>
    </form>
  </div>
</div>

<script>
  document.getElementById('renameModal').addEventListener('show.bs.modal', function(e) {
    const btn = e.relatedTarget;
    this.querySelector('#renameNodeId').value = btn.dataset.nodeId;
    this.querySelector('#newName').value = btn.dataset.nodeName;
  });
  document.getElementById('deleteModal').addEventListener('show.bs.modal', function(e) {
    const btn = e.relatedTarget;
    this.querySelector('#deleteNodeId').value = btn.dataset.nodeId;
    this.querySelector('#deleteNodeName').textContent = btn.dataset.nodeName;
  });
</script>

<%- include('partials/footer') %>
